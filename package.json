{
  "name": "project-guardian",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered smart mobile safety system",
  "workspaces": [
    "mobile",
    "shared-schemas"
  ],
  "scripts": {
    "mobile:start": "npm run start --workspace=mobile",
    "mobile:lint": "npm run lint --workspace=mobile",
